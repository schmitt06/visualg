algoritmo "Estrutura de Decisão"

var
  nota: inteiro

inicio

  escreval("---BOLETIM---")
  escreval("Digite a nota: ")
  leia(nota)

  se (nota >= 6) entao
    escreval("Aprovado")
  senao
    se (nota >=4) entao
      escreval("faça a recuperação")
    senao
      escreval("reprovado")

    fimse
    escreva()
  fimse

fimalgoritmo
